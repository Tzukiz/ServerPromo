import cv2
import os
import sys
import RPi.GPIO as GPIO
import time
from edge_impulse_linux.image import ImageImpulseRunner

# --- 1. SETUP HARDWARE (MECHATRONICS) ---
PUL_PIN = 17  # GPIO 17 (Physical Pin 11)
DIR_PIN = 27  # GPIO 27 (Physical Pin 13)

GPIO.setmode(GPIO.BCM)
GPIO.setup(PUL_PIN, GPIO.OUT)
GPIO.setup(DIR_PIN, GPIO.OUT)

# Fungsi gerak slow untuk demo pelajar
def gerak_conveyor(steps, delay=0.002):
    GPIO.output(DIR_PIN, GPIO.HIGH) # Arah ke depan
    for _ in range(steps):
        GPIO.output(PUL_PIN, GPIO.HIGH)
        time.sleep(delay)
        GPIO.output(PUL_PIN, GPIO.LOW)
        time.sleep(delay)

# --- 2. SETUP AI (EDGE IMPULSE) ---
# Pastikan nama fail .eim ni sama dengan yang kau transfer tadi
model_file = "modelfail_anda.eim" 

def main():
    # Guna 'with' supaya runner tutup sendiri kalau error
    with ImageImpulseRunner(model_file) as runner:
        try:
            model_info = runner.init()
            print(f"Model [{model_info['project']['name']}] sedia!")
            
            # Start Webcam USB
            videoCapture = cv2.VideoCapture(0)

            while True:
                print("\n--- Konveyor Bergerak (Mencari Buah) ---")
                # Gerak 800 step (separuh pusingan jika microstep 1600)
                gerak_conveyor(800) 
                
                # Berhenti sekejap untuk ambil gambar yang jelas (tak blur)
                time.sleep(1) 
                success, img = videoCapture.read()
                if not success:
                    print("Gagal akses kamera!")
                    break

                # --- BAHAGIAN FIX ERROR DISINI ---
                # Kita pecahkan tuple: features (data AI) & img_cropped (gambar)
                features, img_cropped = runner.get_features_from_image(img)
                
                # Sekarang hantar 'features' sahaja ke classify
                res = runner.classify(features)
                # ---------------------------------

                if "classification" in res:
                    print("HASIL ANALISIS AI:")
                    # Cari label yang paling tinggi peratusannya
                    predictions = res['classification']
                    for label, value in predictions.items():
                        print(f"- {label}: {value:.2f}")
                        
                        # Logik sorting: Jika keyakinan lebih 80%
                        if value > 0.8:
                            print(f">>> OUTPUT: {label.upper()} DIKESAN")

                # Tunggu 2 saat sebelum kitaran seterusnya
                time.sleep(2) 

        except Exception as e:
            print(f"Ralat berlaku: {e}")
        finally:
            GPIO.cleanup() # Reset pin GPIO supaya tak panas
            videoCapture.release()
            print("Sistem ditutup dengan selamat.")

if __name__ == "__main__":
    main()
