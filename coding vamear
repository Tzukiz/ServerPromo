import cv2
import threading
import RPi.GPIO as GPIO
import time
from edge_impulse_linux.image import ImageImpulseRunner

# --- 1. SETUP HARDWARE ---
PUL_PIN = 17 
DIR_PIN = 27 
GPIO.setmode(GPIO.BCM)
GPIO.setup(PUL_PIN, GPIO.OUT)
GPIO.setup(DIR_PIN, GPIO.OUT)

# Global variables
latest_frame = None
latest_result = "Mencari..."
is_running = True

# --- THREAD 1: CAMERA GRABBER (Laju Giler) ---
class CameraStream:
    def __init__(self):
        self.stream = cv2.VideoCapture(0)
        self.stream.set(cv2.CAP_PROP_FRAME_WIDTH, 320)
        self.stream.set(cv2.CAP_PROP_FRAME_HEIGHT, 240)
        self.stream.set(cv2.CAP_PROP_BUFFERSIZE, 1)
        (self.grabbed, self.frame) = self.stream.read()
        self.stopped = False

    def start(self):
        threading.Thread(target=self.update, args=()).start()
        return self

    def update(self):
        while not self.stopped:
            if not self.grabbed:
                self.stop()
            else:
                (self.grabbed, self.frame) = self.stream.read()

    def read(self):
        return self.frame

    def stop(self):
        self.stopped = True
        self.stream.release()

# --- THREAD 2: AI & MOTOR (Otak Projek) ---
def ai_logic_thread(model_file):
    global latest_result, latest_frame, is_running
    
    with ImageImpulseRunner(model_file) as runner:
        runner.init()
        while is_running:
            if latest_frame is not None:
                # 1. Gerak Motor NEMA 17
                GPIO.output(DIR_PIN, GPIO.HIGH)
                for _ in range(400): # Gerak sikit
                    GPIO.output(PUL_PIN, GPIO.HIGH)
                    time.sleep(0.002) # Speed delay yang kau nak tadi
                    GPIO.output(PUL_PIN, GPIO.LOW)
                    time.sleep(0.002)

                # 2. Proses AI
                features, _ = runner.get_features_from_image(latest_frame)
                res = runner.classify(features)
                
                if "classification" in res:
                    predictions = res['classification']
                    best_label = max(predictions, key=predictions.get)
                    if predictions[best_label] > 0.7:
                        latest_result = f"{best_label.upper()} ({predictions[best_label]:.2f})"
                    else:
                        latest_result = "Tiada Objek"
            
            time.sleep(0.1) # Rehat sikit untuk CPU Pi 4

# --- 3. MAIN DISPLAY (Paparan) ---
def main():
    global latest_frame, is_running
    
    model_path = "modelfail_anda.eim" # TUKAR SINI
    cam = CameraStream().start()
    
    # Start AI Thread
    t_ai = threading.Thread(target=ai_logic_thread, args=(model_path,))
    t_ai.daemon = True
    t_ai.start()

    print("Sistem SMOOTH GILER bermula... Tekan 'q' untuk keluar")

    while True:
        frame = cam.read()
        latest_frame = frame # Bagi frame kat AI Thread
        
        # Lukis info atas skrin
        cv2.rectangle(frame, (0, 0), (320, 35), (0, 0, 0), -1)
        cv2.putText(frame, latest_result, (10, 25), 
                    cv2.FONT_HERSHEY_SIMPLEX, 0.6, (0, 255, 0), 2)

        cv2.imshow('PREVIEW SMOOTH - ISKANDAR', frame)
        
        if cv2.waitKey(1) & 0xFF == ord('q'):
            is_running = False
            break

    cam.stop()
    cv2.destroyAllWindows()
    GPIO.cleanup()

if __name__ == "__main__":
    main()
