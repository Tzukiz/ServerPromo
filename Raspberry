import cv2
import os
import time

# ==========================================
# 1. TUKAR NAMA BUAH DI SINI SEBELUM MULA
# ==========================================
# Kalau nak ambil gambar Epal, tulis: "epal"
# Kalau nak ambil gambar Oren, tukar jadi: "oren"
NAMA_BUAH = "epal" 

# Folder simpan gambar (Auto create di Desktop)
FOLDER_SIMPAN = f"/home/pi/Desktop/dataset/{NAMA_BUAH}"

# Cipta folder kalau belum wujud
if not os.path.exists(FOLDER_SIMPAN):
    os.makedirs(FOLDER_SIMPAN)
    print(f"Folder '{NAMA_BUAH}' dah sedia di Desktop!")

# Setup Kamera (0 = Webcam USB)
cap = cv2.VideoCapture(0)
cap.set(3, 640) # Lebar
cap.set(4, 480) # Tinggi

count = 0
print("--- CARA GUNA ---")
print("1. Tekan kekunci 'S' untuk Simpan Gambar")
print("2. Tekan kekunci 'Q' untuk Keluar")

while True:
    success, img = cap.read()
    if not success:
        print("Kamera tak jumpa! Cucuk betul-betul.")
        break

    # Tunjuk video live
    cv2.imshow("Kamera Pengumpul Data", img)
    
    # Baca keyboard
    key = cv2.waitKey(1) & 0xFF

    # --- TEKAN 'S' UNTUK SNAP ---
    if key == ord('s'):
        timestamp = int(time.time())
        filename = f"{FOLDER_SIMPAN}/{NAMA_BUAH}_{timestamp}.jpg"
        cv2.imwrite(filename, img)
        print(f"Gambar Disimpan: {filename} (Total: {count+1})")
        count += 1
        
    # --- TEKAN 'Q' UNTUK KELUAR ---
    elif key == ord('q'):
        break

cap.release()
cv2.destroyAllWindows()




import cv2
import os
import sys
import RPi.GPIO as GPIO
from RPLCD.i2c import CharLCD
from edge_impulse_linux.image import ImageImpulseRunner

# --- 1. SETUP HARDWARE ---
LED_PIN = 18
GPIO.setmode(GPIO.BCM)
GPIO.setwarnings(False)
GPIO.setup(LED_PIN, GPIO.OUT)
GPIO.output(LED_PIN, GPIO.LOW)

# Setup LCD (Guna 0x27 atau 0x3f)
try:
    lcd = CharLCD('PCF8574', 0x27)
    lcd.clear()
    lcd.write_string("Sistem AI Ready")
except Exception as e:
    print(f"LCD tak jumpa! Check wiring/reboot: {e}")

# --- 2. SETUP AI ---
# Pastikan PATH fail .eim ni betul!
modelfile = "/home/iskandar/kesan_telur.eim"

runner = ImageImpulseRunner(modelfile)
model_info = runner.init()
print("AI Model Berjaya Load!")

# Guna ID kamera terus (0 untuk USB webcam)
video_device_id = 0 

try:
    # Kita panggil classifier guna ID, bukan objek 'cap' terus
    for res, img in runner.classifier(video_device_id):
        found = False
        
        if "bounding_boxes" in res["result"]:
            for bb in res["result"]["bounding_boxes"]:
                if bb['value'] > 0.6: # Yakin lebih 60%
                    label = bb['label']
                    score = bb['value']
                    found = True
                    
                    # Update LCD & LED
                    lcd.clear()
                    lcd.write_string(f"Objek: {label}")
                    lcd.cursor_pos = (1, 0)
                    lcd.write_string(f"Yakin: {int(score*100)}%")
                    
                    GPIO.output(LED_PIN, GPIO.HIGH)
                    print(f"Jumpa: {label} ({score:.2f})")

        if not found:
            GPIO.output(LED_PIN, GPIO.LOW)

        cv2.imshow('AI Hardware Test', img)
        if cv2.waitKey(1) & 0xFF == ord('q'):
            break

finally:
    GPIO.output(LED_PIN, GPIO.LOW)
    GPIO.cleanup()
    cv2.destroyAllWindows()
    if runner:
        runner.stop()
